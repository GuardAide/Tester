<!DOCTYPE html>
<html>
<head>
  <title>GuardAide Text Emergency</title>
  <style>
    body { font-family:sans-serif; text-align:center; padding:20px; }
    button { padding:15px; margin:10px; font-size:16px; width:250px; }
  </style>
</head>
<body>

<h2>Text Emergency Contacts</h2>
<p id="info"></p>

<div id="buttons"></div>

<script>
// --- Get URL parameters ---
const params = new URLSearchParams(window.location.search);
const JULIE LYNCH = params.get('name') || "the person";
const contacts = [];
for (let i = 1; i <= 5; i++) { // up to 5 contacts
  const contact = params.get('contact' + i);
  if (contact) contacts.push(contact);
}

// --- Show info
document.getElementById('info').innerText = `You are about to text ${JULIE LYNCH}'s emergency contact(s).`;

// --- Create buttons
const btnDiv = document.getElementById('buttons');
contacts.forEach((num, index) => {
  const btn = document.createElement('button');
  btn.innerText = `Text Contact ${index + 1}`;
  btn.onclick = function() {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function(pos) {
        const lat = pos.coords.latitude;
