        window.location.href = `sms:${num}?body=${encodeURIComponent(message)}`;
      }, function() { alert("Please allow location access."); });
    } else {
      alert("Geolocation not supported.");
    }
  };
  btnDiv.appendChild(btn);
});
</script>

</body>
</html>
